<!DOCTYPE html>
<html>

<head>

    <title>Data Warga</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body>

<div class="container mt-4">

    <h2>Data Warga</h2>

    <a
        href="/dashboard"
        class="btn btn-secondary mb-3">

        Dashboard

    </a>

    <a
        href="/warga/tambah"
        class="btn btn-primary mb-3">

        Tambah Warga

    </a>

    <table class="table table-bordered">

        <thead>

            <tr>
                <th>ID</th>
                <th>Nama</th>
                <th>Alamat</th>
                <th>No HP</th>
                <th>Aksi</th>
            </tr>

        </thead>

        <tbody>

            <% warga.forEach(item => { %>

                <tr>

                    <td><%= item.id_warga %></td>
                    <td><%= item.nama %></td>
                    <td><%= item.alamat %></td>
                    <td><%= item.no_hp %></td>

                    <td>

                        <a
                            href="/warga/edit/<%= item.id_warga %>"
                            class="btn btn-warning btn-sm">

                            Edit

                        </a>

                        <a
                            href="/warga/hapus/<%= item.id_warga %>"
                            class="btn btn-danger btn-sm"
                            onclick="return confirm('Yakin hapus data?')">

                            Hapus

                        </a>

                    </td>

                </tr>

            <% }) %>

        </tbody>

    </table>

</div>

</body>
</html>