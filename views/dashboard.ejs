<!DOCTYPE html>
<html>

<head>

    <title>Dashboard Kas RT</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body class="bg-light">

<nav class="navbar navbar-dark bg-primary">

    <div class="container">

        <span class="navbar-brand">
            Sistem Kas RT
        </span>

        <div>

            <span class="text-white me-3">
                <%= user.username %>
            </span>

            <a
                href="/auth/logout"
                class="btn btn-danger">

                Logout

            </a>

        </div>

    </div>

</nav>

<div class="container mt-4">

    <div class="row">

        <div class="col-md-3 mb-3">

            <div class="card shadow">

                <div class="card-body">

                    <h5>Total Warga</h5>

                    <h2>
                        <%= dashboard.total_warga %>
                    </h2>

                </div>

            </div>

        </div>

        <div class="col-md-3 mb-3">

            <div class="card shadow">

                <div class="card-body">

                    <h5>Total Tagihan</h5>

                    <h2>
                        <%= dashboard.total_tagihan %>
                    </h2>

                </div>

            </div>

        </div>

        <div class="col-md-3 mb-3">

            <div class="card shadow">

                <div class="card-body">

                    <h5>Sudah Lunas</h5>

                    <h2>
                        <%= dashboard.lunas %>
                    </h2>

                </div>

            </div>

        </div>

        <div class="col-md-3 mb-3">

            <div class="card shadow">

                <div class="card-body">

                    <h5>Belum Lunas</h5>

                    <h2>
                        <%= dashboard.belum_lunas %>
                    </h2>

                </div>

            </div>

        </div>

    </div>

    <div class="row">

        <div class="col-md-4">

            <div class="card shadow">

                <div class="card-body">

                    <h4>Total Kas Masuk</h4>

                    <h2>
                        Rp <%= Number(dashboard.total_kas_masuk).toLocaleString('id-ID') %>
                    </h2>

                </div>

            </div>

        </div>

        <div class="col-md-4">
    
            <div class="card shadow">
    
                <div class="card-body">
    
                    <h4>Total Kas Keluar</h4>
    
                    <h2>
                        Rp <%= Number(dashboard.total_kas_keluar).toLocaleString('id-ID') %>
                    </h2>
    
                </div>
    
            </div>
    
        </div>
        <div class="col-md-4">
    
            <div class="card shadow">
    
                <div class="card-body">
    
                    <h4>Total Kas</h4>
    
                    <h2>
                        Rp <%= Number(dashboard.total_kas).toLocaleString('id-ID') %>
                    </h2>
    
                </div>
    
            </div>
    
        </div>

    </div>
    


    

    <div class="mt-4">

        <a href="/warga" class="btn btn-primary">
            Data Warga
        </a>

        <a href="/tagihan" class="btn btn-warning">
            Tagihan
        </a>

        <a href="/pembayaran" class="btn btn-success">
            Pembayaran
        </a>

        <a href="/pengeluaran" class="btn btn-info">
            Pengeluaran
        </a>
        <a href="/laporan" class="btn btn-info">
            Laporan
        </a>

    </div>

</div>

</body>
</html>