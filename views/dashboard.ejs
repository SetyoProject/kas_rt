

<%- include('layout/navbar') %>
<%- include('layout/sidebar') %>

<!-- Header -->
<section class="content-header">
    <div class="container-fluid">

        <div class="card bg-primary shadow border-0">
            <div class="card-body">
                <h2 class="mb-2">
                    Selamat Datang <%= user.username %>
                </h2>

                <p class="mb-0">
                    Kelola pemasukan dan pengeluaran kas RT dengan mudah dan transparan.
                </p>
            </div>
        </div>

    </div>
</section>


<!-- Ringkasan -->
<section class="content">
    <div class="container-fluid">

        <div class="row">

            <!-- Kas Masuk -->
            <div class="col-lg-4 col-md-6">
                <div class="small-box bg-success">

                    <div class="inner">
                        <h3>
                            Rp <%= Number(dashboard.total_kas_masuk).toLocaleString('id-ID') %>
                        </h3>

                        <p>Total Kas Masuk</p>
                    </div>

                    <div class="icon">
                        <i class="fas fa-arrow-down"></i>
                    </div>

                </div>
            </div>


            <!-- Kas Keluar -->
            <div class="col-lg-4 col-md-6">
                <div class="small-box bg-danger">

                    <div class="inner">
                        <h3>
                            Rp <%= Number(dashboard.total_kas_keluar).toLocaleString('id-ID') %>
                        </h3>

                        <p>Total Kas Keluar</p>
                    </div>

                    <div class="icon">
                        <i class="fas fa-arrow-up"></i>
                    </div>

                </div>
            </div>


            <!-- Saldo Kas -->
            <div class="col-lg-4 col-md-6">
                <div class="small-box bg-info">

                    <div class="inner">
                        <h3>
                             Rp <%= Number(dashboard.total_kas).toLocaleString('id-ID') %>
                        </h3>

                        <p>Saldo Kas</p>
                    </div>

                    <div class="icon">
                        <i class="fas fa-wallet"></i>
                    </div>

                </div>
            </div>

        </div>

        <!-- Grafik + Statistik -->
    <div class="row">
    
        <!-- Informasi -->
        <div class="col-lg-4 col-md-6">
    
            <!-- Jumlah Warga -->
            <div class="card bg-primary">
                <div class="card-body">
    
                    <h3>
                        <%= dashboard.total_warga %>
                    </h3>
    
                    <p>
                        <i class="fas fa-users"></i>
                        Jumlah Warga
                    </p>
    
                </div>
            </div>
    
    
            <!-- Belum Bayar -->
            <div class="card bg-danger">
                <div class="card-body">
    
                    <h3>
                        <%= dashboard.belum_lunas %>
                    </h3>
    
                    <p>
                        <i class="fas fa-times-circle"></i>
                        Belum Bayar
                    </p>
    
                </div>
            </div>
    
    
            <!-- Lunas -->
            <div class="card bg-success">
                <div class="card-body">
    
                    <h3>
                        <%= dashboard.lunas %>
                    </h3>
    
                    <p>
                        <i class="fas fa-check-circle"></i>
                        Lunas
                    </p>
    
                </div>
            </div>
    
        </div>
    
    </div>
    </div>
</section>

<%- include('layout/footer') %>