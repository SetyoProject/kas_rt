<%- include('../layout/navbar') %>

<%- include('../layout/sidebar') %>




    <section class="content">

        <div class="container-fluid mt-4">

            <div class="d-flex justify-content-between align-items-center mb-3">

                <h2>Data Tagihan</h2>

                <a
                    href="/tagihan/tambah"
                    class="btn btn-primary">

                    <i class="fas fa-plus"></i>
                    Tambah Tagihan

                </a>

            </div>


            <div class="card">

                <div class="card-header">

                    <h3 class="card-title">
                        Daftar Tagihan Warga
                    </h3>

                </div>


                <div class="card-body">

                    <table class="table table-bordered table-striped">

                        <thead class="table-dark">

                            <tr>

                                <th>No.</th>
                                <th>Nama Warga</th>
                                <th>Bulan</th>
                                <th>Tahun</th>
                                <th>Tagihan</th>
                                <th>Total Bayar</th>
                                <th>Sisa</th>
                                <th>Status</th>
                                <th width="100">Aksi</th>

                            </tr>

                        </thead>


                        <tbody>

                            <% if(tagihan.length === 0){ %>

                                <tr>

                                    <td colspan="9" class="text-center">

                                        Belum ada data tagihan

                                    </td>

                                </tr>

                            <% } %>


                            <% tagihan.forEach(item => { %>

                            <tr>

                                <td>
                                    <%= tagihan.indexOf(item) + 1 %>
                                </td>

                                <td>
                                    <%= item.nama %>
                                </td>

                                <td>
                                    <%= item.bulan %>
                                </td>

                                <td>
                                    <%= item.tahun %>
                                </td>

                                <td>

                                    Rp
                                    <%= Number(item.jumlah_tagihan).toLocaleString('id-ID') %>

                                </td>

                                <td>

                                    Rp
                                    <%= Number(item.total_bayar).toLocaleString('id-ID') %>

                                </td>

                                <td>

                                    Rp
                                    <%= Number(item.jumlah_tagihan - item.total_bayar).toLocaleString('id-ID') %>

                                </td>


                                <td>

                                    <% if(item.status === 'Lunas'){ %>

                                        <span class="badge bg-success">

                                            Lunas

                                        </span>

                                    <% } else { %>

                                        <span class="badge bg-danger">

                                            Belum Lunas

                                        </span>

                                    <% } %>

                                </td>


                                <td>

                                    <a
                                        href="/tagihan/hapus/<%= item.id_tagihan %>"
                                        class="btn btn-danger btn-sm"
                                        onclick="return confirm('Yakin ingin menghapus data ini?')">

                                        <i class="fas fa-trash"></i>
                                        Hapus

                                    </a>

                                </td>

                            </tr>

                            <% }) %>

                        </tbody>

                    </table>

                </div>

            </div>

        </div>

    </section>
<%- include('../layout/footer') %>