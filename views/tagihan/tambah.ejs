<!DOCTYPE html>
<html>
<head>

    <title>Tambah Tagihan</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

</head>
<body>

<div class="container mt-4">

    <h2>Tambah Tagihan</h2>

    <form action="/tagihan/simpan" method="POST">

        <div class="mb-3">

            <label>Warga</label>

            <select
                name="id_warga"
                class="form-control"
                required>

                <option value="">
                    Pilih Warga
                </option>

                <% warga.forEach(item => { %>

                    <option value="<%= item.id_warga %>">

                        <%= item.nama %>

                    </option>

                <% }) %>

            </select>

        </div>

        <div class="mb-3">

            <label>Bulan</label>

            <input
                type="text"
                name="bulan"
                class="form-control"
                required>

        </div>

        <div class="mb-3">

            <label>Tahun</label>

            <input
                type="number"
                name="tahun"
                class="form-control"
                value="2026">

        </div>

        <div class="mb-3">

            <label>Jumlah Tagihan</label>

            <input
                type="number"
                name="jumlah_tagihan"
                class="form-control"
                required>

        </div>

        <button
            type="submit"
            class="btn btn-success">

            Simpan

        </button>

        <a
            href="/tagihan"
            class="btn btn-secondary">

            Kembali

        </a>

    </form>

</div>

</body>
</html>