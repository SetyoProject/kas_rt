<!DOCTYPE html>
<html>
<head>

    <title>Monitoring Kas RT</title>

    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet">

</head>
<body>

<div class="container mt-4">

    <h2 class="text-center mb-4">
        Transparansi Dana Kas RT
    </h2>

    <div class="row">

        <div class="col-md-4">

            <div class="card shadow">

                <div class="card-body">

                    <h5>Total Kas Masuk</h5>

                    <h2>

                        Rp
                        <%= Number(total_kas_masuk).toLocaleString('id-ID') %>

                    </h2>

                </div>

            </div>

        </div>


        <div class="col-md-4">

            <div class="card shadow">

                <div class="card-body">

                    <h5>Total Kas Keluar</h5>

                    <h2>

                        Rp
                        <%= Number(total_kas_keluar).toLocaleString('id-ID') %>

                    </h2>

                </div>

            </div>

        </div>


        <div class="col-md-4">

            <div class="card shadow">

                <div class="card-body">

                    <h5>Saldo Kas</h5>

                    <h2>

                        Rp
                        <%= Number(saldo_kas).toLocaleString('id-ID') %>

                    </h2>

                </div>

            </div>

        </div>

    </div>


    <div class="card shadow mt-4">

        <div class="card-header">

            <h4>Riwayat Transaksi</h4>

        </div>

        <div class="card-body">

            <table class="table table-bordered">

                <thead class="table-dark">

                    <tr>

                        <th>No</th>
                        <th>Tanggal</th>
                        <th>Jenis</th>
                        <th>Keterangan</th>
                        <th>Nominal</th>

                    </tr>

                </thead>

                <tbody>

                    <% transaksi.forEach((item,index)=>{ %>

                    <tr>

                        <td>
                            <%= index+1 %>
                        </td>

                        <td>
                            <%= item.tanggal.toISOString().split('T')[0] %>
                        </td>

                        <td>

                            <% if(item.jenis === 'Pemasukan'){ %>

                                <span class="badge bg-success">
                                    Pemasukan
                                </span>

                            <% } else { %>

                                <span class="badge bg-danger">
                                    Pengeluaran
                                </span>

                            <% } %>

                        </td>

                        <td>
                            <%= item.keterangan %>
                        </td>

                        <td>

                            Rp
                            <%= Number(item.nominal).toLocaleString('id-ID') %>

                        </td>

                    </tr>

                    <% }) %>

                </tbody>

            </table>

        </div>

    </div>

</div>

</body>
</html>