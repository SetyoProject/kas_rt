<!DOCTYPE html>
<html>
<head>
    <title>Monitoring Kas RT</title>

    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet">

    <link
        rel="stylesheet"
        href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

    <style>

        body{
            background:#f4f7fe;
        }

        .card-custom{
            border:none;
            border-radius:20px;
        }

        .icon-box{
            width:60px;
            height:60px;
            border-radius:50%;
            display:flex;
            align-items:center;
            justify-content:center;
            font-size:28px;
            color:white;
        }

        .table{
            vertical-align: middle;
        }

    </style>

</head>

<body>

<div class="container py-5">

    <div class="text-center mb-5">

        <h2 class="fw-bold">
            Transparansi Dana Kas RT
        </h2>

        <p class="text-secondary">
            Monitoring pemasukan dan pengeluaran kas secara terbuka
        </p>

    </div>


    <div class="row g-4">

        <!-- Kas Masuk -->
        <div class="col-md-4">

            <div class="card card-custom shadow-sm">

                <div class="card-body d-flex justify-content-between">

                    <div>

                        <small class="text-secondary">
                            Total Kas Masuk
                        </small>

                        <h3 class="fw-bold text-success mt-2">

                            Rp
                            <%= Number(total_kas_masuk).toLocaleString('id-ID') %>

                        </h3>

                    </div>

                    <div class="icon-box bg-success">

                        <i class="bi bi-arrow-down-circle"></i>

                    </div>

                </div>

            </div>

        </div>


        <!-- Kas Keluar -->
        <div class="col-md-4">

            <div class="card card-custom shadow-sm">

                <div class="card-body d-flex justify-content-between">

                    <div>

                        <small class="text-secondary">
                            Total Kas Keluar
                        </small>

                        <h3 class="fw-bold text-danger mt-2">

                            Rp
                            <%= Number(total_kas_keluar).toLocaleString('id-ID') %>

                        </h3>

                    </div>

                    <div class="icon-box bg-danger">

                        <i class="bi bi-arrow-up-circle"></i>

                    </div>

                </div>

            </div>

        </div>


        <!-- Saldo -->
        <div class="col-md-4">

            <div class="card card-custom shadow-sm">

                <div class="card-body d-flex justify-content-between">

                    <div>

                        <small class="text-secondary">
                            Saldo Kas Saat Ini
                        </small>

                        <h3 class="fw-bold text-primary mt-2">

                            Rp
                            <%= Number(saldo_kas).toLocaleString('id-ID') %>

                        </h3>

                    </div>

                    <div class="icon-box bg-primary">

                        <i class="bi bi-wallet2"></i>

                    </div>

                </div>

            </div>

        </div>

    </div>



    <!-- Tabel -->
    <div class="card card-custom shadow-sm mt-5">

        <div class="card-header bg-white border-0 py-3">

            <h4 class="fw-bold">
                <i class="bi bi-clock-history"></i>
                Riwayat Transaksi
            </h4>

        </div>

        <div class="card-body">

            <div class="table-responsive">

                <table class="table table-hover">

                    <thead>

                        <tr class="table-light">

                            <th>No</th>
                            <th>Tanggal</th>
                            <th>Jenis</th>
                            <th>Keterangan</th>
                            <th>Nominal</th>

                        </tr>

                    </thead>

                    <tbody>

                        <% transaksi.forEach((item,index)=>{ %>

                        <tr>

                            <td>
                                <%= index+1 %>
                            </td>

                            <td>
                                <%= item.tanggal.toISOString().split('T')[0] %>
                            </td>

                            <td>

                                <% if(item.jenis === 'Pemasukan'){ %>

                                    <span class="badge rounded-pill bg-success px-3 py-2">

                                        <i class="bi bi-arrow-down"></i>
                                        Pemasukan

                                    </span>

                                <% } else { %>

                                    <span class="badge rounded-pill bg-danger px-3 py-2">

                                        <i class="bi bi-arrow-up"></i>
                                        Pengeluaran

                                    </span>

                                <% } %>

                            </td>

                            <td>

                                <%= item.keterangan %>

                            </td>

                            <td class="fw-semibold">

                                Rp
                                <%= Number(item.nominal).toLocaleString('id-ID') %>

                            </td>

                        </tr>

                        <% }) %>

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>

</body>
</html>