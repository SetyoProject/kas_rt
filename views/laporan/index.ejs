<!DOCTYPE html>
<html>
<head>

<title>Laporan Pembayaran</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

</head>
<body>

<div class="container mt-4">

<h2>Laporan Pembayaran</h2>

<a href="/dashboard" class="btn btn-secondary mb-3">
Dashboard
</a>

<a href="/laporan/belum-lunas" class="btn btn-danger mb-3">
Belum Lunas
</a>

<a href="/laporan/pemasukan" class="btn btn-success mb-3">
Total Pemasukan
</a>

<table class="table table-bordered">

<thead>

<tr>
<th>Tanggal</th>
<th>Nama</th>
<th>Bulan</th>
<th>Tahun</th>
<th>Jumlah</th>
<th>Petugas</th>
</tr>

</thead>

<tbody>

<% laporan.forEach(item => { %>

<tr>

<td>
<%= item.tanggal_bayar.toISOString().split('T')[0] %>
</td>

<td>
<%= item.nama %>
</td>

<td>
<%= item.bulan %>
</td>

<td>
<%= item.tahun %>
</td>

<td>
Rp <%= Number(item.jumlah_bayar).toLocaleString('id-ID') %>
</td>

<td>
<%= item.username %>
</td>

</tr>

<% }) %>

</tbody>

</table>

</div>

</body>
</html>