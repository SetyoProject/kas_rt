
<%- include('../layout/navbar') %>

<%- include('../layout/sidebar') %>

    <section class="content">

        <div class="container-fluid mt-4">

            <div class="d-flex justify-content-between align-items-center mb-3">

                <h2>Laporan Kas</h2>

            </div>


            <!-- FILTER -->
            <div class="card">

                <div class="card-header">
                    <h3 class="card-title">
                        Filter Periode
                    </h3>
                </div>

                <div class="card-body">

                    <form method="GET" action="/laporan">

                        <div class="row">

                            <div class="col-md-4">

                                <label>Tanggal Awal</label>

                                <input
                                    type="date"
                                    name="tanggal_awal"
                                    class="form-control"
                                    value="<%= tanggal_awal %>">

                            </div>


                            <div class="col-md-4">

                                <label>Tanggal Akhir</label>

                                <input
                                    type="date"
                                    name="tanggal_akhir"
                                    class="form-control"
                                    value="<%= tanggal_akhir %>">

                            </div>


                            <div class="col-md-4">

                                <label>&nbsp;</label>

                                <button class="btn btn-primary form-control">

                                    <i class="fas fa-search"></i>
                                    Filter

                                </button>

                            </div>

                        </div>

                    </form>

                </div>

            </div>


            <!-- RINGKASAN -->
            <div class="row mt-3">

                <div class="col-md-4">

                    <div class="small-box bg-success">

                        <div class="inner">

                            <h3>
                                Rp <%= Number(total_kas_masuk).toLocaleString('id-ID') %>
                            </h3>

                            <p>Total Kas Masuk</p>

                        </div>

                        <div class="icon">
                            <i class="fas fa-arrow-down"></i>
                        </div>

                    </div>

                </div>


                <div class="col-md-4">

                    <div class="small-box bg-danger">

                        <div class="inner">

                            <h3>
                                Rp <%= Number(total_kas_keluar).toLocaleString('id-ID') %>
                            </h3>

                            <p>Total Kas Keluar</p>

                        </div>

                        <div class="icon">
                            <i class="fas fa-arrow-up"></i>
                        </div>

                    </div>

                </div>


                <div class="col-md-4">

                    <div class="small-box bg-info">

                        <div class="inner">

                            <h3>
                                Rp <%= Number(saldo_kas).toLocaleString('id-ID') %>
                            </h3>

                            <p>Saldo Kas</p>

                        </div>

                        <div class="icon">
                            <i class="fas fa-wallet"></i>
                        </div>

                    </div>

                </div>

            </div>


            <!-- DETAIL TRANSAKSI -->
            <div class="card">

                <div class="card-header">

                    <h3 class="card-title">
                        Detail Transaksi
                    </h3>

                </div>


                <div class="card-body">

                    <table class="table table-bordered table-striped">

                        <thead class="table-dark">

                            <tr>

                                <th>No</th>
                                <th>Tanggal</th>
                                <th>Jenis</th>
                                <th>Keterangan</th>
                                <th>Nominal</th>

                            </tr>

                        </thead>


                        <tbody>

                            <% if (transaksi.length === 0) { %>

                                <tr>

                                    <td colspan="5" class="text-center">

                                        Tidak ada data transaksi

                                    </td>

                                </tr>

                            <% } %>


                            <% transaksi.forEach((item, index) => { %>

                                <tr>

                                    <td>
                                        <%= index + 1 %>
                                    </td>

                                    <td>
                                        <%= item.tanggal.toISOString().split('T')[0] %>
                                    </td>

                                    <td>

                                        <% if(item.jenis === 'Pemasukan'){ %>

                                            <span class="badge bg-success">
                                                Pemasukan
                                            </span>

                                        <% } else { %>

                                            <span class="badge bg-danger">
                                                Pengeluaran
                                            </span>

                                        <% } %>

                                    </td>

                                    <td>
                                        <%= item.keterangan %>
                                    </td>

                                    <td>

                                        Rp
                                        <%= Number(item.nominal).toLocaleString('id-ID') %>

                                    </td>

                                </tr>

                            <% }) %>

                        </tbody>

                    </table>

                </div>

            </div>

        </div>

    </section>

<%- include('../layout/footer') %>