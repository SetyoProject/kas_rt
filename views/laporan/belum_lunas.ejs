<!DOCTYPE html>
<html>
<head>

<title>Belum Lunas</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

</head>
<body>

<div class="container mt-4">

<h2>Daftar Warga Belum Lunas</h2>

<a href="/laporan" class="btn btn-secondary mb-3">
Kembali
</a>

<table class="table table-bordered">

<thead>

<tr>
<th>Nama</th>
<th>Bulan</th>
<th>Tahun</th>
<th>Tagihan</th>
<th>Total Bayar</th>
<th>Sisa</th>
</tr>

</thead>

<tbody>

<% data.forEach(item => { %>

<tr>

<td><%= item.nama %></td>

<td><%= item.bulan %></td>

<td><%= item.tahun %></td>

<td>
Rp <%= Number(item.jumlah_tagihan).toLocaleString('id-ID') %>
</td>

<td>
Rp <%= Number(item.total_bayar).toLocaleString('id-ID') %>
</td>

<td>
Rp <%= Number(item.jumlah_tagihan-item.total_bayar).toLocaleString('id-ID') %>
</td>

</tr>

<% }) %>

</tbody>

</table>

</div>

</body>
</html>