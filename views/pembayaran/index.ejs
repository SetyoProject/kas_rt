<!DOCTYPE html>
<html>
<head>

<title>Pembayaran</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

</head>
<body>

<div class="container mt-4">

<h2>Data Pembayaran</h2>

<a href="/dashboard" class="btn btn-secondary mb-3">
Dashboard
</a>

<a href="/pembayaran/tambah" class="btn btn-success mb-3">
Input Pembayaran
</a>

<table class="table table-bordered">

<thead>

<tr>
<th>ID</th>
<th>Nama</th>
<th>Bulan</th>
<th>Tahun</th>
<th>Tanggal Bayar</th>
<th>Jumlah</th>
</tr>

</thead>

<tbody>

<% pembayaran.forEach(item => { %>

<tr>

<td><%= item.id_pembayaran %></td>
<td><%= item.nama %></td>
<td><%= item.bulan %></td>
<td><%= item.tahun %></td>
<td><%= item.tanggal_bayar.toISOString().split('T')[0] %></td>

<td>
Rp <%= Number(item.jumlah_bayar).toLocaleString('id-ID') %>
</td>

</tr>

<% }) %>

</tbody>

</table>

</div>

</body>
</html>