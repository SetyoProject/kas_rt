
<%- include('../layout/navbar') %>

<%- include('../layout/sidebar') %>


    <section class="content">

        <div class="container-fluid mt-4">

            <div class="d-flex justify-content-between align-items-center mb-3">

                <h2>Data Pembayaran</h2>

                <a href="/pembayaran/tambah" class="btn btn-success">
                    <i class="fas fa-plus"></i>
                    Input Pembayaran
                </a>

            </div>


            <div class="card">

                <div class="card-header">
                    <h3 class="card-title">
                        Daftar Pembayaran Warga
                    </h3>
                </div>

                <div class="card-body">

                    <table class="table table-bordered table-striped">

                        <thead class="table-dark">

                            <tr>
                                <th>No</th>
                                <th>Nama</th>
                                <th>Bulan</th>
                                <th>Tahun</th>
                                <th>Tanggal Bayar</th>
                                <th>Jumlah</th>
                            </tr>

                        </thead>

                        <tbody>
                            <% pembayaran.forEach((item, index) => { %>
                            <tr>
                                <td>
                                    <%= index + 1 %>
                                </td>
                                <td>
                                    <%= item.nama %>
                                </td>
                                <td>
                                    <%= item.bulan %>
                                </td>
                                <td>
                                    <%= item.tahun %>
                                </td>
                                <td>
                                    <%= item.tanggal_bayar.toISOString().split('T')[0] %>
                                </td>
                                <td>
                                    Rp <%= Number(item.jumlah_bayar).toLocaleString('id-ID') %>
                                </td>
                            </tr>

                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </section>



<%- include('../layout/footer') %>