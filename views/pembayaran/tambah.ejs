<!DOCTYPE html>
<html>
<head>

<title>Input Pembayaran</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

</head>
<body>

<div class="container mt-4">

<h2>Input Pembayaran</h2>

<form action="/pembayaran/simpan" method="POST">

<div class="mb-3">

<label>Tagihan</label>

<select
name="id_tagihan"
class="form-control"
required>

<option value="">
Pilih Tagihan
</option>

<% tagihan.forEach(item => { %>

<option value="<%= item.id_tagihan %>">

<%= item.nama %>
-
<%= item.bulan %>
-
Rp <%= Number(item.jumlah_tagihan).toLocaleString('id-ID') %>

</option>

<% }) %>

</select>

</div>

<div class="mb-3">

<label>Tanggal Bayar</label>

<input
type="date"
name="tanggal_bayar"
class="form-control"
required>

</div>

<div class="mb-3">

<label>Jumlah Bayar</label>

<input
type="number"
name="jumlah_bayar"
class="form-control"
required>

</div>

<button
type="submit"
class="btn btn-success">

Simpan

</button>

<a
href="/pembayaran"
class="btn btn-secondary">

Kembali

</a>

</form>

</div>

</body>
</html>