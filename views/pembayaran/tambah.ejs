
<%- include('../layout/navbar') %>

<%- include('../layout/sidebar') %>



    <section class="content">

        <div class="container-fluid mt-4">

            <div class="card">

                <div class="card-header">

                    <h3 class="card-title">
                        Input Pembayaran
                    </h3>

                </div>


                <form action="/pembayaran/simpan" method="POST">

                    <div class="card-body">

                        <div class="mb-3">

                            <label class="form-label">
                                Tagihan
                            </label>

                            <select
                                name="id_tagihan"
                                class="form-control"
                                required>

                                <option value="">
                                    Pilih Tagihan
                                </option>

                                <% tagihan.forEach(item => { %>

                                <option value="<%= item.id_tagihan %>">

                                    <%= item.nama %>
                                    -
                                    <%= item.bulan %>
                                    -
                                    Rp <%= Number(item.jumlah_tagihan).toLocaleString('id-ID') %>

                                </option>

                                <% }) %>

                            </select>
                        </div>

                        <div class="mb-3">

                            <label class="form-label">
                                Tanggal Bayar
                            </label>

                            <input
                                type="date"
                                name="tanggal_bayar"
                                class="form-control"
                                required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">
                                Jumlah Bayar
                            </label>

                            <input
                                type="number"
                                name="jumlah_bayar"
                                class="form-control"
                                required>
                        </div>
                    </div>

                    <div class="card-footer">
                        <button
                            type="submit"
                            class="btn btn-success"
                            <i class="fas fa-save"></i>
                            Simpan
                        </button>
                        <a
                            href="/pembayaran"
                            class="btn btn-secondary">

                            <i class="fas fa-arrow-left"></i>
                            Kembali
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </section>
<%- include('../layout/footer') %>