<!DOCTYPE html>
<html>
<head>

    <title>Data Pengeluaran</title>

    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet">

</head>
<body>

<div class="container mt-4">

    <h2>Data Pengeluaran</h2>

    <a href="/dashboard" class="btn btn-secondary mb-3">
        Dashboard
    </a>

    <a href="/pengeluaran/tambah" class="btn btn-primary mb-3">
        Tambah Pengeluaran
    </a>

    <table class="table table-bordered table-striped">

        <thead class="table-dark">

            <tr>

                <th>No</th>
                <th>Tanggal</th>
                <th>Keterangan</th>
                <th>Jumlah</th>
                <th>Aksi</th>

            </tr>

        </thead>

        <tbody>

            <% if (pengeluaran.length === 0) { %>

                <tr>

                    <td colspan="5" class="text-center">

                        Belum ada data pengeluaran

                    </td>

                </tr>

            <% } %>

            <% pengeluaran.forEach((item, index) => { %>

                <tr>

                    <td>
                        <%= index + 1 %>
                    </td>

                    <td>
                        <%= item.tanggal.toISOString().split('T')[0] %>
                    </td>

                    <td>
                        <%= item.keterangan %>
                    </td>

                    <td>

                        Rp
                        <%= Number(item.jumlah).toLocaleString('id-ID') %>

                    </td>

                    <td>

                        <a
                            href="/pengeluaran/hapus/<%= item.id_pengeluaran %>"
                            class="btn btn-danger btn-sm"
                            onclick="return confirm('Yakin ingin menghapus data ini?')">

                            Hapus

                        </a>

                    </td>

                </tr>

            <% }) %>

        </tbody>

    </table>

</div>

</body>
</html>