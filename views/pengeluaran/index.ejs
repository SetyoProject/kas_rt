<%- include('../layout/navbar') %>  
<%- include('../layout/sidebar') %>

    <section class="content">
        <div class="container-fluid mt-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2>Data Pengeluaran</h2>
                <a href="/pengeluaran/tambah" class="btn btn-primary">
                    <i class="fas fa-plus"></i>
                    Tambah Pengeluaran
                </a>
            </div>

            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">
                        Daftar Pengeluaran Kas
                    </h3>
                </div>

                <div class="card-body">
                    <table class="table table-bordered table-striped">
                        <thead class="table-dark">
                            <tr>
                                <th>No</th>
                                <th>Tanggal</th>
                                <th>Keterangan</th>
                                <th>Jumlah</th>
                                <th width="120">Aksi</th>
                            </tr>
                        </thead>

                        <tbody>
                            <% if (pengeluaran.length === 0) { %>
                                <tr>
                                    <td colspan="5" class="text-center">
                                        Belum ada data pengeluaran
                                    </td>
                                </tr>
                            <% } %>

                            <% pengeluaran.forEach((item, index) => { %>
                                <tr>
                                    <td>
                                        <%= index + 1 %>
                                    </td>
                                    <td>
                                        <%= item.tanggal.toISOString().split('T')[0] %>
                                    </td>
                                    <td>
                                        <%= item.keterangan %>
                                    </td>
                                    <td>
                                        Rp
                                        <%= Number(item.jumlah).toLocaleString('id-ID') %>
                                    </td>
                                    <td>
                                        <a
                                            href="/pengeluaran/hapus/<%= item.id_pengeluaran %>"
                                            class="btn btn-danger btn-sm"
                                            onclick="return confirm('Yakin ingin menghapus data ini?')">

                                            <i class="fas fa-trash"></i>
                                            Hapus
                                        </a>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </section>

<%- include('../layout/footer') %>
